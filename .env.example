# Server Configuration
PORT=3000
NODE_ENV=development
# Public base URL. In production, set this to your real domain to avoid Host
# header injection and to build correct QR URLs.
APP_URL=http://localhost:3000

# ── Pairing & control model ───────────────────────────────────────────────────
# How a phone takes control after scanning the QR / entering the code:
#   instant  → scanning takes control immediately (default; good for private use)
#   approve  → scanning sends a request; the board owner approves on the TV (public)
PAIRING_MODE=instant
# How long a displayed pair code stays valid before the board rotates it (minutes).
# A photo of an old QR is useless after this window.
PAIR_CODE_TTL_MIN=10
# How long an idle session (no sockets, no writes) is kept before purge (hours).
SESSION_IDLE_HOURS=24

# ── Transport security ────────────────────────────────────────────────────────
# Comma-separated allow-list of Origins permitted to open the WebSocket.
# Leave empty to allow any origin (fine for LAN / self-host without a domain).
# In production behind a domain, set e.g. https://board.example.com
ALLOWED_ORIGINS=

# ── Rate limiting (per connection) ────────────────────────────────────────────
RATE_LIMIT_PER_SEC=10
RATE_LIMIT_BURST=20

# ── Content moderation ────────────────────────────────────────────────────────
# Profanity filter (true/false). On by default.
CONTENT_FILTER=true
# Extra blocked words (comma-separated, case-insensitive) on top of the built-in list.
CONTENT_BLOCKLIST=
# Log submitted message text (session id + text) for moderation/traceability.
# Off by default for privacy; enable for public boards if you need an audit trail.
AUDIT_LOG=false

# Supabase (optional — app works without it, sessions won't persist across restarts)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Sentry (optional — error monitoring)
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project

# PostHog (optional — analytics)
VITE_POSTHOG_KEY=your-posthog-project-api-key
VITE_POSTHOG_HOST=https://app.posthog.com
